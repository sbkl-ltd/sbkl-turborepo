{
  "name": "@sbkl-turborepo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "bun with-env next dev",
    "format": "biome format --write . --config-path ../packages/biome/biome.json",
    "lint": "biome lint . --config-path ../packages/biome/biome.json",
    "start": "bun run with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env.local --"
  },
  "dependencies": {
    "@convex-dev/react-query": "^0.1.0",
    "@sbkl-turborepo/api": "*",
    "@sbkl-turborepo/schemas": "*",
    "@sbkl-turborepo/ui": "*",
    "@tanstack/react-query": "^5.90.20",
    "@vercel/config": "^0.0.28",
    "@workos-inc/authkit-nextjs": "^2.13.0",
    "@workos-inc/node": "^8.0.0",
    "convex": "^1.31.7",
    "convex-helpers": "^0.1.111",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sbkl-turborepo/biome": "*",
    "@sbkl-turborepo/typescript": "*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
