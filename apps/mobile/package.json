{
  "name": "@sbkl-turborepo/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "setup": "bun run prebuild:ios && bun run ios",
    "android": "expo run:android",
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "format": "biome format --write . --config-path ../packages/biome/biome.json",
    "ios": "expo run:ios",
    "lint": "biome lint . --config-path ../packages/biome/biome.json",
    "prebuild:ios": "bunx expo prebuild --platform ios --clean",
    "start": "expo start",
    "dev": "expo start --clear --ios",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@convex-dev/react-query": "^0.1.0",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/slot": "^1.2.0",
    "@sbkl-turborepo/api": "*",
    "@sbkl-turborepo/schemas": "*",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.20",
    "@workos-inc/node": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "expo": "~55.0.0-preview.7",
    "expo-auth-session": "~55.0.2",
    "expo-build-properties": "~55.0.3",
    "expo-constants": "~55.0.2",
    "expo-dev-client": "~55.0.2",
    "expo-font": "~55.0.3",
    "expo-glass-effect": "~55.0.3",
    "expo-image": "~55.0.3",
    "expo-linking": "~55.0.3",
    "expo-localization": "~55.0.2",
    "expo-router": "~55.0.0-beta.4",
    "expo-secure-store": "~55.0.2",
    "expo-splash-screen": "~55.0.3",
    "expo-status-bar": "~55.0.2",
    "expo-symbols": "~55.0.3",
    "expo-system-ui": "~55.0.3",
    "expo-web-browser": "~55.0.3",
    "jose": "^6.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.20.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "resend": "^6.9.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.2.7",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@expo/metro-config": "~55.0.1",
    "@sbkl-turborepo/biome": "*",
